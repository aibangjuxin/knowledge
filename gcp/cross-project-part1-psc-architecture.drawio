<?xml version="1.0" encoding="UTF-8"?>
<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Title -->
    <mxCell id="title" value="Part 1: Cross-Project PSC Architecture" style="text;html=1;stroke=none;fill=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1A202C;" vertex="1" parent="1">
      <mxGeometry x="500" y="20" width="600" height="40" as="geometry"/>
