    <!-- EDGES -->
    <!-- Client → DNS -->
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=2;endArrow=none;endFill=0;" edge="1" parent="1" source="client" target="dns">
