    <mxCell id="subtitle" value="A Project (Consumer) → Google Internal Backbone → B Project (Producer)" style="text;html=1;stroke=none;fill=none;align=center;verticalAlign=middle;fontSize=13;fontColor=#718096;" vertex="1" parent="1">
