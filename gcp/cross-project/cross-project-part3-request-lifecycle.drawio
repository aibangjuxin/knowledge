    <mxCell id="t1" value="• TLS/WAF/公网治理都在 A Project 入口层完成" style="text;html=1;stroke=none;fill=none;align=left;fontSize=10;fontColor=#1A202C;" vertex="1" parent="ts_hdr">
      <mxGeometry y="35" width="640" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="t2" value="• B Project 只接收 Service Attachment 放行后的流量" style="text;html=1;stroke=none;fill=none;align=left;fontSize=10;fontColor=#1A202C;" vertex="1" parent="ts_hdr">
      <mxGeometry y="60" width="640" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="t3" value="• Producer 看到的源 IP 是 PSC NAT 后的地址，不是 Consumer 原始 IP" style="text;html=1;stroke=none;fill=none;align=left;fontSize=10;fontColor=#1A202C;" vertex="1" parent="ts_hdr">
      <mxGeometry y="85" width="640" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="t4" value="• ILB health check 必须通过，否则 Backend Service 不会选中该 Pod" style="text;html=1;stroke=none;fill=none;align=left;fontSize=10;fontColor=#1A202C;" vertex="1" parent="ts_hdr">
      <mxGeometry y="110" width="640" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="t5" value="• PSC NEG、Service Attachment、ILB 必须在同一 Region" style="text;html=1;stroke=none;fill=none;align=left;fontSize=10;fontColor=#1A202C;" vertex="1" parent="ts_hdr">
      <mxGeometry y="135" width="640" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="t6" value="• PeerAuthentication STRICT 模式下，无 Sidecar 的 Pod 无法通过 mTLS 验证" style="text;html=1;stroke=none;fill=none;align=left;fontSize=10;fontColor=#1A202C;" vertex="1" parent="ts_hdr">
      <mxGeometry y="160" width="640" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="t7" value="• 整条链路是串联架构，任一组件故障都会导致 5xx" style="text;html=1;stroke=none;fill=none;align=left;fontSize=10;fontColor=#1A202C;" vertex="1" parent="ts_hdr">
      <mxGeometry y="185" width="640" height="20" as="geometry"/>
